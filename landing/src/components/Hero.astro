---
import Heatmap from './Heatmap.astro'
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).hero
const base = import.meta.env.BASE_URL
const brew = 'brew install --cask nanako0129/tokenbar/tokenbar'
const repo = 'https://github.com/Nanako0129/TokenBar'
---

<section class="hero" id="top">
  <Heatmap />
  <div class="container hero-inner">
    <div class="hero-copy">
      <p class="eyebrow rise" style="animation-delay:.85s">{c.eyebrow}</p>
      <h1 class:list={['rise', { cjk: locale === 'zh-tw' }]} style="animation-delay:.92s" set:html={c.h1} />
      <p class="lede rise" style="animation-delay:1s" set:html={c.lede} />

      <div class="cta rise" style="animation-delay:1.08s">
        <button class="brew" id="brew" type="button" title="Copy install command" data-copied={c.copied}>
          <span class="prompt">$</span>
          <code>{brew}</code>
          <span class="copy" aria-hidden="true">{c.copy}</span>
        </button>
        <a class="btn btn-ghost" href={repo}>{c.github}</a>
      </div>

      <p class="statline mono rise" style="animation-delay:1.16s">{c.statline}</p>
    </div>

    <div class="hero-pop" aria-hidden="false">
      <!-- mirrors the NSPopover open: springs out of the status item above -->
      <div class="pop-shell">
        <div class="pop-float">
          <img
            class="pop-img"
            src={`${base}screenshots/native/popover-hero.png`}
            alt={c.popAlt}
            width="365"
            height="849"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const b = document.getElementById('brew')
  if (b) {
    const cmd = b.querySelector('code')?.textContent ?? ''
    const label = b.querySelector('.copy')
    const idle = label?.textContent ?? 'copy'
    b.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(cmd)
        if (label) {
          label.textContent = b.dataset.copied || 'copied'
          b.classList.add('done')
          setTimeout(() => { label.textContent = idle; b.classList.remove('done') }, 1600)
        }
      } catch {}
    })
  }
</script>

<style>
  .hero {
    position: relative;
    /* popover column hugs the menu bar, like a real NSPopover */
    padding-top: calc(var(--menubar-h) + 14px);
    min-height: clamp(620px, 90vh, 980px);
    display: grid;
    align-items: center;
  }
  .hero-inner {
    position: relative; z-index: 2;
    display: grid;
    grid-template-columns: 1.05fr minmax(280px, 380px);
    gap: clamp(32px, 5vw, 72px);
    align-items: center;
  }

  .hero-copy { text-align: left; padding: clamp(28px, 6vh, 72px) 0 6vh; }
  .hero h1 {
    font-size: clamp(44px, 6.6vw, 92px);
    margin: 16px 0 0;
    text-wrap: balance;
  }
  /* CJK glyphs run much wider per line — drop the scale, open the leading */
  .hero h1.cjk { font-size: clamp(34px, 4.7vw, 62px); line-height: 1.18; }
  .hero h1 .hot {
    background: linear-gradient(120deg, var(--accent-bright), var(--accent-pink));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .lede {
    max-width: 560px; margin: 24px 0 0;
    color: var(--ink-dim); font-size: clamp(17px, 2vw, 20px);
  }
  .lede strong { color: var(--ink); font-weight: 600; }

  .cta { margin: 36px 0 0; display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
  .brew {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--font-mono); font-size: 14px;
    padding: 12px 14px 12px 16px; border-radius: 999px;
    background: color-mix(in oklab, var(--glass-scrim) 80%, transparent);
    border: 1px solid var(--line-strong); color: var(--ink-dim);
    cursor: pointer;
    -webkit-backdrop-filter: blur(10px) saturate(1.3);
    backdrop-filter: blur(10px) saturate(1.3);
    transition: border-color .18s, transform .18s;
  }
  .brew:hover { border-color: var(--accent); transform: translateY(-2px); }
  .brew .prompt { color: var(--accent-bright); }
  .brew code { color: var(--ink); }
  .brew .copy {
    font-size: 11px; text-transform: uppercase; letter-spacing: .12em;
    color: var(--faint); border-left: 1px solid var(--line-strong); padding-left: 12px;
  }
  .brew.done .copy { color: var(--gauge-ok); }
  @media (max-width: 560px) { .brew { font-size: 12px; } .brew code { font-size: 11px; } }

  .statline {
    margin-top: 40px; font-size: 13px; letter-spacing: .04em;
    color: var(--muted);
    border-top: 1px solid var(--line); padding-top: 20px;
    max-width: 560px;
  }

  /* --- the popover ------------------------------------------------------ */
  .hero-pop {
    position: relative; z-index: 3;
    /* the bottom edge deliberately presses into the next section */
    margin-bottom: clamp(-170px, -12vw, -70px);
    align-self: start;
  }
  .pop-shell {
    /* springs from the status item pinned above in the menu bar */
    transform-origin: calc(100% - 52px) -18px;
    animation: popIn .72s cubic-bezier(.34, 1.2, .44, 1) .55s backwards;
  }
  @keyframes popIn {
    0% { opacity: 0; transform: scale(.1) translateY(-10px); }
    58% { opacity: 1; transform: scale(1.03) translateY(0); }
    80% { transform: scale(.994); }
    100% { transform: scale(1); }
  }
  .pop-float { animation: popDrift 9s ease-in-out 2.2s infinite alternate; }
  @keyframes popDrift {
    from { transform: translateY(0); }
    to { transform: translateY(-10px); }
  }
  .pop-img {
    display: block; width: 100%; height: auto;
    border-radius: 15px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow:
      0 60px 130px -45px rgba(0, 0, 0, 0.85),
      0 24px 60px -30px color-mix(in oklab, var(--accent-deep) 55%, transparent);
  }

  @media (max-width: 880px) {
    .hero { padding-top: calc(var(--menubar-h) + 36px); }
    .hero-inner { grid-template-columns: 1fr; }
    .hero-copy { padding-bottom: 0; }
    .hero-pop {
      margin: 12px auto -64px;
      width: min(75vw, 330px);
    }
    .pop-shell { transform-origin: 80% -20px; }
  }
</style>
