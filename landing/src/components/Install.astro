---
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).install
const brew = 'brew install --cask nanako0129/tokenbar/tokenbar'
---

<section class="section install" id="install">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2>{c.h2}</h2>
      <p set:html={c.intro} />
    </div>

    <div class="channel glass reveal" style="--rd:.1s">
      <div class="ch-head">
        <h3>TokenBar</h3>
        <span class="pill pill-hot mono">{c.pill}</span>
      </div>
      <p class="ch-desc" set:html={c.desc} />
      <div class="term quiet">
        <pre class="term-body"><code><span class="c">$</span> {brew}</code></pre>
        <button class="term-copy mono" data-cmd={brew} data-copied={c.copied} type="button">{c.copyBtn}</button>
      </div>
    </div>

    <p class="legacy-note reveal" style="--rd:.18s" set:html={c.legacy} />
  </div>
</section>

<script is:inline>
  document.querySelectorAll('.term-copy[data-cmd]').forEach((b) => {
    b.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(b.dataset.cmd || '')
        const t = b.textContent
        b.textContent = b.dataset.copied || 'Copied ✓'
        b.classList.add('ok')
        setTimeout(() => { b.textContent = t; b.classList.remove('ok') }, 1600)
      } catch {}
    })
  })
</script>

<style>
  .section-head code { font-family: var(--font-mono); font-size: .9em; color: var(--accent-bright); }
  .channel {
    max-width: 640px; margin-inline: auto;
    padding: 30px 28px;
    display: flex; flex-direction: column; gap: 14px;
  }
  .ch-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .ch-head h3 { font-size: 26px; }
  .pill {
    font-size: 11px; letter-spacing: .08em; text-transform: uppercase;
    padding: 5px 11px; border-radius: 999px;
    border: 1px solid var(--line-strong); color: var(--muted); white-space: nowrap;
  }
  .pill-hot {
    color: var(--accent-bright);
    border-color: color-mix(in oklab, var(--accent) 48%, var(--line-strong));
    background: color-mix(in oklab, var(--accent) 14%, transparent);
  }
  .ch-desc { color: var(--muted); font-size: 15px; }
  .ch-desc strong { color: var(--ink-dim); }

  /* in-glass terminal: translucent ink fill, no nested blur */
  .term {
    border: 1px solid var(--line); border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--ink) 7%, transparent);
    padding: 14px;
  }
  .term-body code {
    font-family: var(--font-mono); font-size: clamp(11px, 3vw, 13.5px); color: var(--ink);
    white-space: pre-wrap; overflow-wrap: anywhere; word-break: break-word;
  }
  .term-body .c { color: var(--accent-bright); }
  .term-copy {
    width: 100%; margin-top: 12px; padding: 12px; cursor: pointer;
    background: color-mix(in oklab, var(--accent) 22%, transparent);
    color: var(--ink);
    border: 1px solid color-mix(in oklab, var(--accent) 48%, var(--line-strong));
    border-radius: 999px; font-size: 14px; font-weight: 600;
    transition: transform .18s, border-color .18s, background .18s, color .18s;
  }
  .term-copy:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
    background: color-mix(in oklab, var(--accent) 34%, transparent);
  }
  .term-copy.ok { color: var(--gauge-ok); border-color: color-mix(in oklab, var(--gauge-ok) 55%, var(--line-strong)); }

  .legacy-note {
    margin-top: 24px; font-size: 13.5px; color: var(--faint);
    text-align: center; max-width: 70ch; margin-inline: auto;
  }
  .legacy-note code { font-family: var(--font-mono); font-size: .92em; color: var(--accent-bright); }
  .legacy-note a { color: var(--ink-dim); border-bottom: 1px solid var(--line-strong); }
</style>
