---
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).native
const base = import.meta.env.BASE_URL
---

<section class="section native" id="native">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2 set:html={c.h2} />
      <p set:html={c.intro} />
    </div>

    <div class="native-grid">
      <figure class="shot reveal">
        <img
          src={`${base}screenshots/native/hero-wide.png`}
          alt={c.shotAlt}
          loading="lazy"
        />
      </figure>
      <ul class="points glass reveal" style="--rd:.12s">
        {c.points.map((p) => (
          <li>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .section-head em { font-style: normal; color: var(--accent-bright); }
  .native-grid {
    display: grid; grid-template-columns: 1fr 1.05fr;
    gap: clamp(32px, 6vw, 72px); align-items: center;
  }
  .shot {
    border-radius: var(--radius); overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow:
      0 50px 110px -45px rgba(0, 0, 0, 0.8),
      0 24px 60px -30px color-mix(in oklab, var(--accent-deep) 50%, transparent);
  }
  .shot img { display: block; width: 100%; height: auto; }
  .points { list-style: none; display: grid; padding: 10px 28px; }
  .points li { padding: 20px 0; }
  .points li + li { border-top: 1px solid var(--line); }
  .points h3 { font-size: 19px; margin-bottom: 6px; }
  .points h3::before {
    content: ''; display: inline-block; width: 9px; height: 9px;
    border-radius: 3px; margin-right: 11px;
    background: linear-gradient(135deg, var(--accent-bright), var(--accent-deep));
    box-shadow: 0 0 10px -1px var(--accent);
  }
  .points p { color: var(--muted); font-size: 15px; max-width: 52ch; }

  @media (max-width: 880px) {
    .native-grid { grid-template-columns: 1fr; }
    .shot { max-width: 480px; margin-inline: auto; }
  }
</style>
