---
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).credits
const credits = c.items
---

<section class="section credits">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2>{c.h2}</h2>
      <p>{c.intro}</p>
    </div>
    <div class="credit-grid">
      {credits.map((item, i) => (
        <a class="credit-card glass reveal" href={item.href} style={`--ac: var(${item.accent}); --rd: ${(i % 2) * 0.09}s;`}>
          <div class="ch">
            <h3>{item.name}</h3>
            <span class="who mono">{item.who}</span>
          </div>
          <p>{item.body}</p>
          <span class="go mono">{c.go}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .credit-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .credit-card { display: block; padding: 30px 28px; }
  .credit-card:hover {
    border-color: color-mix(in oklab, var(--ac) 55%, var(--glass-edge));
    box-shadow: inset 0 1px 0 var(--glass-sheen),
      0 26px 50px -34px color-mix(in oklab, var(--ac) 60%, transparent);
  }
  .ch { display: flex; align-items: baseline; gap: 12px; margin-bottom: 12px; }
  .ch h3 { font-size: 26px; color: var(--ac); }
  .who { font-size: 13px; color: var(--faint); }
  .credit-card p { color: var(--muted); font-size: 15px; }
  .go { display: inline-block; margin-top: 18px; font-size: 13px; color: var(--ink-dim); }
  @media (max-width: 700px) { .credit-grid { grid-template-columns: 1fr; } }
</style>
