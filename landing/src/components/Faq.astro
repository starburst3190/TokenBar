---
import { t, type Locale } from '../i18n/copy'
const { locale = 'en' } = Astro.props as { locale?: Locale }
const c = t(locale).faq
const faqs = c.items
---

<section class="section faq">
  <div class="container faq-grid">
    <div class="section-head faq-head reveal">
      <p class="eyebrow">{c.eyebrow}</p>
      <h2>{c.h2}</h2>
      <p>{c.intro}</p>
    </div>
    <div class="faq-list glass reveal" style="--rd:.1s">
      {faqs.map((f, i) => (
        <details open={i === 0}>
          <summary>
            <span>{f.q}</span>
            <span class="chev" aria-hidden="true"></span>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: clamp(28px, 5vw, 64px); align-items: start; }
  .faq-head { position: sticky; top: 58px; margin-bottom: 0; }
  /* one glass panel for the whole list — stacking blur per row is how you
     get the murky-slab look (and jank); dividers carry the rhythm instead */
  .faq-list { padding: 8px 24px; }
  details { transition: background .18s; border-radius: var(--radius-sm); }
  details + details { border-top: 1px solid var(--line); }
  details[open] { background: color-mix(in oklab, var(--ink) 4%, transparent); margin: 0 -10px; padding: 0 10px; }
  summary {
    list-style: none; cursor: pointer; padding: 16px 0;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    font-family: var(--font-display); font-weight: 700; font-size: 18px; letter-spacing: -0.01em;
  }
  summary::-webkit-details-marker { display: none; }
  .chev { width: 12px; height: 12px; border-right: 2px solid var(--accent-bright); border-bottom: 2px solid var(--accent-bright); transform: rotate(45deg); transition: transform .2s; flex: 0 0 auto; }
  details[open] .chev { transform: rotate(-135deg); }
  details p { color: var(--muted); font-size: 15px; padding: 0 0 18px; max-width: 62ch; }

  @media (max-width: 820px) {
    .faq-grid { grid-template-columns: 1fr; }
    .faq-head { position: static; }
  }
</style>
